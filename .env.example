# ============================================
# 词汇大冒险 (Word Quest) 环境配置
# 复制本文件为 .env 并填入你的实际值
# ============================================

# JWT 密钥（务必修改为强随机字符串）
JWT_SECRET=your_strong_random_secret_here

# 百度文心一言 API（小智 AI 对话所需）
# 获取地址: https://console.bce.baidu.com/qianfan/ais/console/applicationConsole/application
ERNIE_API_KEY=your_ernie_api_key_here
ERNIE_SECRET_KEY=your_ernie_secret_key_here

# 如果不填 ERNIE Key，小智会使用本地模拟回复（功能受限但不影响游戏运行）
